# Port the bridge listens on. Different from the print-bridge (41960).
PORT=41961

# Bind address. 0.0.0.0 so LAN machines can reach http://10.10.1.30:41961.
# Switch to 127.0.0.1 later if you move this fully behind Cloudflare Tunnel.
BIND=0.0.0.0

# Shared secret. Every request from the web app must include:
#   Authorization: Bearer <API_KEY>
# Generate a long random string (e.g. `openssl rand -hex 32`).
API_KEY=change-me-to-a-long-random-string

# Comma-separated list of allowed browser origins. Must match every origin
# the web app is served from — including https://localhost for the Capacitor
# Android app's WebView.
ALLOWED_ORIGINS=https://shop.holmgraphics.ca,http://localhost:5173,https://localhost

# Comma-separated list of folders the bridge is allowed to serve from.
# These are the client-files root folders on the mapped L: drive.
# The drive must be mapped for the user account the scheduled task runs as.
FILES_ROOTS=L:\ClientFilesA-K,L:\ClientFilesL-Z

# Max size (bytes) the bridge will serve via GET /file. Default 2 GB.
# Bump if you routinely have giant PSDs / production PDFs to download in-app.
MAX_FILE_BYTES=2147483648
