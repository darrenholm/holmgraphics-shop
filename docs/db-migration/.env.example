# docs/db-migration/.env.example — copy to .env and fill in
#
# Do NOT commit .env. This script holds connection strings for both
# the live Azure SQL source and the Railway Postgres target.

# --- Azure SQL (source) ---
# Grab these from the Railway holmgraphics-shop-api service → Variables.
AZURE_DB_SERVER=holmgraphics.database.windows.net
AZURE_DB_NAME=HolmGraphicsMain
AZURE_DB_USER=<from Railway DB_USER>
AZURE_DB_PASSWORD=<from Railway DB_PASSWORD>
AZURE_DB_PORT=1433

# --- Railway Postgres (target) ---
# Full connection URL. Grab from Railway Postgres service → Connect → Postgres
# Connection URL. Start with postgresql:// , includes user/password/host/db.
RAILWAY_DATABASE_URL=postgresql://postgres:xxx@host:port/railway

# --- Behaviour flags ---
# If "true", script aborts before any Railway writes if any row transform
# fails (e.g., ToolSN.EmpName doesn't resolve to an employees.id).
# If "false" (default), script logs the failure and continues with NULL.
STRICT_FK_RESOLUTION=false
