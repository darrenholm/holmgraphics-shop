# Port the bridge listens on. Cloudflare Tunnel forwards to this.
PORT=41960

# Bind address. 127.0.0.1 keeps it localhost-only (use with Cloudflare Tunnel).
# Set to 0.0.0.0 if you also want LAN machines at 10.10.1.30:PORT to reach it directly.
BIND=0.0.0.0

# Shared secret. Every request from the web app must include:
#   Authorization: Bearer <API_KEY>
# Generate a long random string (e.g. from https://www.uuidgenerator.net or `openssl rand -hex 32`).
API_KEY=change-me-to-a-long-random-string

# Comma-separated list of allowed browser origins. Include every domain your web app is served from.
ALLOWED_ORIGINS=https://shop.holmgraphics.ca,http://localhost:5173

# DYMO Connect's local HTTPS service. Rarely needs changing — DYMO Connect tries 41951..41953.
DYMO_BASE=https://127.0.0.1:41951
