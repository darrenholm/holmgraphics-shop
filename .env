# .env — local values, NOT committed (.gitignore)

# Your backend API URL (Railway, local, etc.)
# Leave empty to default to http://localhost:3000/api for local dev
VITE_API_URL=https://holmgraphics-shop-api-production.up.railway.app/api

# Print bridge — see .env.example for explanation.
# URL is concrete; KEY needs the value from C:\tools\holmgraphics-shop\print-bridge\.env on Backoffice0.
VITE_PRINT_BRIDGE_URL=http://10.10.1.30:41960
VITE_PRINT_BRIDGE_KEY=4b676bdb-d61e-4aff-92c8-86d95e6c60dbc4fdd161-2c99-4da0-8be0-d854edc548d2

# Files bridge — L: drive artwork relay. Runs on DesignCentre4 (10.10.1.24), NOT the RIP,
# because Backoffice0 can't talk to the legacy Buffalo LS220 NAS reliably (SMB mismatch).
# KEY must match files-bridge/.env on DesignCentre4.
VITE_FILES_BRIDGE_URL=http://10.10.1.24:41961
VITE_FILES_BRIDGE_KEY=1d94bdf5bd6f769ca9aaf36ac0bd0c17002b84f208dc543e16f905484d3c2988