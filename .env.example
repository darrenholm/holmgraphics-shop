# .env.example — copy to .env and fill in your values
#
# WARNING: VITE_* values are inlined into the public client bundle at build time.
# Anything here ends up readable in the shipped JS / APK. That's fine for the
# print-bridge key (it only authorizes printing to our own LAN/tunnel bridge),
# but never put real secrets (DB passwords, Stripe secret keys, etc.) here.

# Your backend API URL (Railway, local, etc.)
# Leave empty to default to http://localhost:3000/api for local dev
VITE_API_URL=https://your-backend.up.railway.app/api

# --- Print bridge (DYMO label relay on the RIP, 10.10.1.30) ---
#
# VITE_PRINT_BRIDGE_URL: where the Capacitor app / browser reaches the bridge.
#   - LAN-only build (Capacitor app on shop WiFi):    http://10.10.1.30:41960
#   - Remote-capable build (after Cloudflare Tunnel): https://print.holmgraphics.ca
# Per-device override is also supported via the modal's settings cog
# (stored in localStorage as 'hg_bridge_url' / 'hg_bridge_key').
VITE_PRINT_BRIDGE_URL=http://10.10.1.30:41960

# VITE_PRINT_BRIDGE_KEY: must match API_KEY in print-bridge/.env on the RIP.
# Grab it from C:\tools\holmgraphics-shop\print-bridge\.env on Backoffice0.
VITE_PRINT_BRIDGE_KEY=paste-the-RIP-API_KEY-here

# --- Files bridge (L: drive client artwork relay on DesignCentre4, 10.10.1.24) ---
#
# NOTE: The files bridge lives on DesignCentre4, not the RIP. Backoffice0's modern
# Windows can't talk to the legacy Buffalo LS220 NAS (SMB1-only firmware cap),
# while DesignCentre4 already has L: mapped and working. Print bridge and files
# bridge are on different machines — this is intentional.
#
# VITE_FILES_BRIDGE_URL: where the app reaches the files bridge.
#   - LAN-only build (Capacitor app on shop WiFi):    http://10.10.1.24:41961
#   - Remote-capable build (after Cloudflare Tunnel): https://files.holmgraphics.ca
# Per-device override via localStorage keys 'hg_files_url' / 'hg_files_key'.
VITE_FILES_BRIDGE_URL=http://10.10.1.24:41961

# VITE_FILES_BRIDGE_KEY: must match API_KEY in files-bridge/.env on DesignCentre4.
# Generate with `openssl rand -hex 32` and paste the same value in both places.
VITE_FILES_BRIDGE_KEY=paste-the-files-bridge-API_KEY-here
